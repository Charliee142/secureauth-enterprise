DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Defaults to sqlite if unset. For Postgres:
# DATABASE_URL=postgres://secureauth:secureauth@db:5432/secureauth

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=security@secureauth.local

SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

SESSION_INACTIVITY_TIMEOUT_SECONDS=600
ACCOUNT_LOCKOUT_THRESHOLD=3
ACCOUNT_LOCKOUT_COOLDOWN_SECONDS=900
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
REAUTH_WINDOW_SECONDS=300
